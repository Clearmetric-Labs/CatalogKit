{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://clearmetric.dev/spec/impact-output.schema.json",
  "title": "ClearMetric Impact CLI Output",
  "description": "Exact JSON payload emitted by cm impact --format json via emitters/impact.py",
  "type": "object",
  "additionalProperties": false,
  "required": ["selection", "selection_id", "related_ids", "traversed_edges", "warnings", "derivation"],
  "properties": {
    "selection": {
      "type": "string",
      "minLength": 1
    },
    "selection_id": {
      "type": "string",
      "minLength": 1
    },
    "related_ids": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "traversed_edges": {
      "type": "array",
      "items": { "$ref": "#/$defs/traversed_edge" }
    },
    "warnings": {
      "type": "array",
      "items": { "$ref": "#/$defs/warning" }
    },
    "derivation": {
      "type": "array",
      "items": { "$ref": "#/$defs/derivation_entry" }
    }
  },
  "$defs": {
    "traversed_edge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "source_id", "target_id", "confidence", "evidence"],
      "properties": {
        "kind": { "type": "string", "minLength": 1 },
        "source_id": { "type": "string", "minLength": 1 },
        "target_id": { "type": "string", "minLength": 1 },
        "label": { "type": ["string", "null"] },
        "confidence": {
          "type": "string",
          "enum": ["high", "medium", "low"]
        },
        "match_status": { "type": ["string", "null"] },
        "evidence": {
          "type": "array",
          "items": { "type": "object" }
        },
        "derivation": { "type": ["object", "null"] }
      }
    },
    "warning": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message"],
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 },
        "location": { "type": ["string", "null"] },
        "subject_id": { "type": ["string", "null"] }
      }
    },
    "derivation_entry": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "edge": { "type": "string", "minLength": 1 },
        "status": {
          "type": "string",
          "enum": ["complete", "partial", "failed", "skipped"]
        },
        "confidence": {
          "type": "string",
          "enum": ["high", "medium", "low"]
        }
      },
      "oneOf": [
        { "required": ["id", "status", "confidence"] },
        { "required": ["edge", "status", "confidence"] }
      ]
    }
  }
}
